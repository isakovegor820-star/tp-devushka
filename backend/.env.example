# --- скопируйте в .env и заполните ---

# Ключ Anthropic (обязательно). Получить: https://console.anthropic.com/
ANTHROPIC_API_KEY=sk-ant-...

# Порт бэкенда (nginx проксирует сюда). На slava-hunter.ru порт 3030 занят — берём 3031.
PORT=3031

# Модель. По умолчанию самая умная — claude-opus-4-8.
# Для публичного виджета с большим трафиком можно удешевить:
#   claude-sonnet-5     — дешевле, почти то же качество
#   claude-haiku-4-5    — самая дешёвая и быстрая
MODEL=claude-opus-4-8

# Максимум токенов в ответе (баланс длина/стоимость)
MAX_TOKENS=4096

# Разрешённые Origin для CORS (через запятую)
ALLOWED_ORIGINS=https://slava-hunter.ru,https://www.slava-hunter.ru

# Лимит запросов к /api/chat на один IP в минуту
RATE_LIMIT_PER_MIN=30

# --- Заявки на участие (POST /api/lead) ---

# Лимит заявок с одного IP в минуту
RATE_LIMIT_LEAD_PER_MIN=5

# Куда складывать заявки (JSONL). По умолчанию ./data рядом с бэкендом.
# ВНИМАНИЕ: содержит персональные данные — каталог в .gitignore, права 0600.
# LEADS_DIR=/var/lib/tp-devushka/data

# Если задать оба — каждая заявка дублируется в Telegram.
# Токен даёт @BotFather; chat_id — id вашего чата/канала с ботом.
# TELEGRAM_BOT_TOKEN=123456:AA...
# TELEGRAM_CHAT_ID=-1001234567890
